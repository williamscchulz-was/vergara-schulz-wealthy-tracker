rules_version = '2';

// ============================================================
//  Ledger — Firestore Security Rules
// ------------------------------------------------------------
//  Projeto: wealthy-tracker-68658
//
//  Este arquivo reflete EXATAMENTE o que está deployado em produção
//  (verificado no console em 2026-04). Só os dois UIDs do casal têm
//  read/write sob household/**. Qualquer outro usuário autenticado é
//  bloqueado, e qualquer caminho fora de household é negado por default
//  (não há outra regra `match`, então o default-deny do Firestore vale).
//
//  Os UIDs abaixo são identificadores do Firebase Auth — NÃO são
//  credenciais (ninguém consegue se autenticar "como" um UID sem ser
//  dono da conta Google). Por isso podem viver no repo. NÃO confundir
//  com walletIds (esses sim, ver §9 do CLAUDE.md).
//
//  Pra deployar: firebase deploy --only firestore:rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /household/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid in [
          '17wwkKWjQfQEUVpHvWKclPrISCp1', // William
          'hzOG3tI87FXY35HCFQCpanGxtoJ3'  // Flávia
        ];
    }
  }
}
